             (1 << START_COUNTDOWN);

    // Configure PORTC buttons as input with internal pull-ups (Active LOW)
    DDRC &= ~((1 << SET_TIME) | (1 << SET_DATE) | (1 << SET_ALARM) | (1 << VIEW_ALARMS)| (1 << STOP_ALARM));
